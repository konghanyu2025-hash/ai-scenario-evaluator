{
  "name": "@aise/web",
  "version": "0.1.0",
  "private": true,
  "description": "Web workspace for AI Scenario Evaluator.",
  "scripts": {
    "predev": "pnpm --filter @aise/shared build && pnpm --filter @aise/providers build && pnpm --filter @aise/core build",
    "dev": "next dev",
    "prebuild": "pnpm --filter @aise/shared build && pnpm --filter @aise/providers build && pnpm --filter @aise/core build",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aise/core": "workspace:*",
    "@aise/providers": "workspace:*",
    "@aise/shared": "workspace:*",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
